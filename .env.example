# Gemini API Key for LLM processing
GEMINI_API_KEY=your_gemini_api_key_here

# Twilio Credentials for Voice Services
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# Django Settings
DEBUG=True
SECRET_KEY=your_django_secret_key_here

# Database Configuration (PostgreSQL recommended)
DATABASE_NAME=remi_ai_db
DATABASE_USER=db_user
DATABASE_PASSWORD=db_password
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432

# Public URL
# Use ngrok for local development: https://your-ngrok-id.ngrok-free.app
BASE_URL=http://your-public-url.com

# Redis Configuration (Used for Celery/Task Queues)
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# Main Backend Webhook URL (To send interview results back)
BACKEND_WEBHOOK_URL=http://localhost:8000/api/interviews/voice-callback/
